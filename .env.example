BACKEND_PORT=8010
PROJECTS_DIR=./projects

# Use mock for a portable first run. Set a real backend after SAM3 and checkpoints are available.
SAM_BACKEND=mock
SAM_DEVICE=cuda:0
CUDA_VISIBLE_DEVICES=0

SAM_REPO_PATH=./sam3
SAM_CHECKPOINT_PATH=./checkpoints/sam3.pt
SAM31_CHECKPOINT_PATH=./checkpoints/sam3.1_multiplex.pt
SAM_PRECISION=bfloat16

# Frontend dev server only. Release builds are served by FastAPI.
FRONTEND_PORT=5173
VITE_BACKEND_URL=http://127.0.0.1:8010
